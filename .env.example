# Kredensial Discord
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_client_id
GUILD_ID=optional_guild_id_for_fast_command_deploy

# Permission bot
OWNER_ID=your_discord_user_id
ADMIN_ROLE_IDS=role_id_1,role_id_2
DEVELOPER_ROLE_IDS=role_id_3
MODERATOR_ROLE_IDS=role_id_4
ALLOWED_ROLE_IDS=role_id_5

# Cooldown command admin dalam detik
ADMIN_COMMAND_COOLDOWN_SECONDS=5

# Railway / Express
PORT=3000

# Debug logger
DEBUG=false
